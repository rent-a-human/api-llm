# Flight Tracker 3D Environment Configuration

# OpenSky Network API Configuration
VITE_OPENSKY_BASE_URL=https://opensky-network.org/api
VITE_UPDATE_INTERVAL=30000
VITE_MAX_FLIGHTS=1000

# Development Settings
VITE_ENABLE_DEBUG=true
VITE_LOG_LEVEL=info

# Performance Configuration
VITE_MAX_TRAIL_LENGTH=100
VITE_TARGET_FPS=60
VITE_ENABLE_POST_PROCESSING=true

# Application Settings
VITE_APP_TITLE="Flight Tracker 3D"
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_FLIGHT_PREDICTION=true
VITE_ENABLE_ATMOSPHERIC_EFFECTS=true
VITE_ENABLE_REAL_TIME_UPDATES=true

# Analytics (Optional)
# VITE_ANALYTICS_ID=your-analytics-id

# Error Reporting (Optional)
# VITE_SENTRY_DSN=your-sentry-dsn