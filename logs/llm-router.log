ont-size: 4rem;\\n  filter: drop-shadow(2px 2px 4px rgba(0, 0, 0, 0.3));\\n}\\n\\n/* Card Content */\\n.card-content {\\n  padding: 25px;\\n}\\n\\n.card-header {\\n  display: flex;\\n  justify-content: space-between;\\n  align-items: flex-start;\\n  margin-bottom: 15px;\\n}\\n\\n.destination-name {\\n  font-size: 1.5rem;\\n  font-weight: bold;\\n  color: #2c3e50;\\n  margin: 0;\\n  flex: 1;\\n}\\n\\n.rating {\\n  display: flex;\\n  align-items: center;\\n  gap: 5px;\\n  background: #f8f9fa;\\n  padding: 5px 10px;\\n  border-radius: 15px;\\n}\\n\\n.stars {\\n  font-size: 0.9rem;\\n}\\n\\n.rating-value {\\n  font-weight: bold;\\n  color: #2c3e50;\\n  font-size: 0.9rem;\\n}\\n\\n/* Description */\\n.destination-description {\\n  color: #6c757d;\\n  line-height: 1.6;\\n  margin-bottom: 20px;\\n  font-size: 0.95rem;\\n}\\n\\n/* Card Footer */\\n.card-footer {\\n  display: flex;\\n  justify-content: space-between;\\n  align-items: center;\\n  border-top: 1px solid #e9ecef;\\n  padding-top: 20px;\\n}\\n\\n.price-info {\\n  display: flex;\\n  flex-direction: column;\\n}\\n\\n.price {\\n  font-size: 1.8rem;\\n  font-weight: bold;\\n  color: #28a745;\\n}\\n\\n.duration {\\n  font-size: 0.85rem;\\n  color: #6c757d;\\n  margin-top: 2px;\\n}\\n\\n/* Book Button */\\n.book-button {\\n  background: linear-gradient(45deg, #667eea, #764ba2);\\n  color: white;\\n  border: none;\\n  padding: 12px 24px;\\n  border-radius: 25px;\\n  font-weight: bold;\\n  cursor: pointer;\\n  transition: all 0.3s ease;\\n  text-transform: uppercase;\\n  letter-spacing: 0.5px;\\n  font-size: 0.9rem;\\n}\\n\\n.book-button:hover {\\n  transform: scale(1.05);\\n  box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);\\n}\\n\\n.book-button:active {\\n  transform: scale(0.98);\\n}\\n\\n/* Responsive Design */\\n@media (max-width: 768px) {\\n  .destinations-container {\\n    grid-template-columns: 1fr;\\n    gap: 20px;\\n    padding: 10px;\\n  }\\n  \\n  .App-header h1 {\\n    font-size: 2rem;\\n  }\\n  \\n  .App-header p {\\n    font-size: 1rem;\\n  }\\n  \\n  .card-footer {\\n    flex-direction: column;\\n    gap: 15px;\\n    align-items: stretch;\\n  }\\n  \\n  .book-button {\\n    width: 100%;\\n  }\\n}\"}}}",
